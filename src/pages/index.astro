<script>
  // Tap-to-flip for touch devices
  document.querySelectorAll('.dbx-flip-card').forEach((card) => {
    card.addEventListener('click', () => {
      card.classList.toggle('flipped');
    });
  });
</script>

<script>
  // Language pair cycling
  const pairs = [
    ['Spanish', 'English'],
    ['Japanese', 'French'],
    ['Arabic', 'German'],
    ['Korean', 'Portuguese'],
    ['Mandarin', 'English'],
  ];
  let idx = 0;
  const fromEl = document.getElementById('dbx-lang-from');
  const toEl = document.getElementById('dbx-lang-to');
  if (fromEl && toEl) {
    setInterval(() => {
      idx = (idx + 1) % pairs.length;
      fromEl.style.opacity = '0';
      toEl.style.opacity = '0';
      setTimeout(() => {
        fromEl.textContent = pairs[idx][0];
        toEl.textContent = pairs[idx][1];
        fromEl.style.opacity = '1';
        toEl.style.opacity = '1';
      }, 400);
    }, 3000);
  }
</script>
