---
import LandingLayout from '../layouts/LandingLayout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<LandingLayout
  title="Dubvox — AI Voice Translation with Voice Cloning"
  description="Upload audio in any language, get it back translated in the speaker's own voice. Real-time voice cloning meets translation."
  product="Dubvox"
  image="/promo/dubvox/dubvox-og.png"
>
  <!-- Hero: Split screen -->
  <section class="relative overflow-hidden flex items-center justify-center px-6 dbx-hero">
    <div class="gradient-mesh"></div>

    <!-- Split screen waveform -->
    <div class="dbx-split" aria-hidden="true">
      <div class="dbx-split-left">
        <div class="dbx-split-label">Original</div>
        <div class="dbx-lang-cycle" id="dbx-lang-from">Spanish</div>
        <div class="dbx-bars dbx-bars-navy">
          <div class="dbx-bar" style="--h: 40%; --delay: 0s;"></div>
          <div class="dbx-bar" style="--h: 70%; --delay: 0.1s;"></div>
          <div class="dbx-bar" style="--h: 30%; --delay: 0.2s;"></div>
          <div class="dbx-bar" style="--h: 85%; --delay: 0.3s;"></div>
          <div class="dbx-bar" style="--h: 50%; --delay: 0.4s;"></div>
          <div class="dbx-bar" style="--h: 65%; --delay: 0.15s;"></div>
          <div class="dbx-bar" style="--h: 45%; --delay: 0.25s;"></div>
          <div class="dbx-bar" style="--h: 75%; --delay: 0.35s;"></div>
        </div>
      </div>
      <div class="dbx-split-divider">
        <div class="dbx-split-arrow">→</div>
      </div>
      <div class="dbx-split-right">
        <div class="dbx-split-label">Translated</div>
        <div class="dbx-lang-cycle" id="dbx-lang-to">English</div>
        <div class="dbx-bars dbx-bars-orange">
          <div class="dbx-bar" style="--h: 55%; --delay: 0.5s;"></div>
          <div class="dbx-bar" style="--h: 35%; --delay: 0.6s;"></div>
          <div class="dbx-bar" style="--h: 80%; --delay: 0.7s;"></div>
          <div class="dbx-bar" style="--h: 45%; --delay: 0.8s;"></div>
          <div class="dbx-bar" style="--h: 70%; --delay: 0.9s;"></div>
          <div class="dbx-bar" style="--h: 60%; --delay: 0.65s;"></div>
          <div class="dbx-bar" style="--h: 40%; --delay: 0.75s;"></div>
          <div class="dbx-bar" style="--h: 50%; --delay: 0.85s;"></div>
        </div>
      </div>
    </div>

    <div class="text-center relative z-10 max-w-3xl mx-auto dbx-hero-content">
      <img src="/promo/dubvox/logo.png" alt="Dubvox logo" width="100" height="100" class="mx-auto mb-5 rounded-full" style="filter: drop-shadow(0 0 30px rgba(234, 138, 46, 0.3));" />
      <span class="section-label">AI Voice Translation</span>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 gradient-text hero-glow">Dubvox</h1>
      <p class="text-lg md:text-xl mb-10 max-w-xl mx-auto" style="color: var(--text-muted);">
        <span class="typewriter">Upload audio in any language, get it back translated in the speaker's own voice. Their voice. Your language.</span>
      </p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href="#waitlist" class="btn-glow inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm active:scale-[0.98]" style="background: linear-gradient(135deg, #EA8A2E, #d97706); color: #fff;">
          Claim Your Spot
        </a>
        <a href="#features" class="inline-block px-7 py-3.5 rounded-full font-semibold text-sm ring-1 ring-white/[0.12] transition-all duration-700 active:scale-[0.98]" style="color: var(--text);">
          Learn More
        </a>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- Problem: Flip cards -->
  <section class="px-6 py-20 md:py-28 section-glow">
    <div class="max-w-4xl mx-auto fade-in reveal-scale">
      <span class="section-label">The Problem</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-12 section-heading">Translation loses the human behind the words</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="dbx-flip-card stagger-card">
          <div class="dbx-flip-inner">
            <div class="dbx-flip-front glass-enhanced glow-reveal">
              <div class="glass-inner p-6 h-full flex flex-col items-center justify-center text-center">
                <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg></div>
                <h3 class="font-semibold mb-2">Robotic Voice</h3>
                <p class="text-sm" style="color: var(--text-muted);">Current tools use generic robot voices. Emotion and personality is lost.</p>
              </div>
            </div>
            <div class="dbx-flip-back">
              <div class="p-6 h-full flex flex-col items-center justify-center text-center">
                <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #EA8A2E;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
                <h3 class="font-semibold mb-2" style="color: #EA8A2E;">Their Real Voice</h3>
                <p class="text-sm" style="color: var(--text-muted);">Dubvox clones the speaker's voice. Emotion, tone, personality preserved.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="dbx-flip-card stagger-card">
          <div class="dbx-flip-inner">
            <div class="dbx-flip-front glass-enhanced glow-reveal">
              <div class="glass-inner p-6 h-full flex flex-col items-center justify-center text-center">
                <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
                <h3 class="font-semibold mb-2">Dubbing is Expensive</h3>
                <p class="text-sm" style="color: var(--text-muted);">Hiring voice actors costs hundreds per minute. Small creators can't afford it.</p>
              </div>
            </div>
            <div class="dbx-flip-back">
              <div class="p-6 h-full flex flex-col items-center justify-center text-center">
                <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #EA8A2E;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
                <h3 class="font-semibold mb-2" style="color: #EA8A2E;">Instant & Affordable</h3>
                <p class="text-sm" style="color: var(--text-muted);">AI-powered dubbing in minutes, not weeks. A fraction of the cost.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="dbx-flip-card stagger-card">
          <div class="dbx-flip-inner">
            <div class="dbx-flip-front glass-enhanced glow-reveal">
              <div class="glass-inner p-6 h-full flex flex-col items-center justify-center text-center">
                <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
                <h3 class="font-semibold mb-2">Language Barriers</h3>
                <p class="text-sm" style="color: var(--text-muted);">Families and teams split by language struggle to connect. Text isn't enough.</p>
              </div>
            </div>
            <div class="dbx-flip-back">
              <div class="p-6 h-full flex flex-col items-center justify-center text-center">
                <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #EA8A2E;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
                <h3 class="font-semibold mb-2" style="color: #EA8A2E;">Any Language Pair</h3>
                <p class="text-sm" style="color: var(--text-muted);">Spanish to English, Japanese to French, Arabic to German. Any combination.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- How it works: Pipeline -->
  <section id="features" class="px-6 py-20 md:py-28 section-glow section-glow-right">
    <div class="max-w-4xl mx-auto fade-in reveal-left">
      <span class="section-label">How It Works</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-12 section-heading">Three steps. Your voice, their language.</h2>
      <div class="dbx-pipeline">
        <div class="dbx-pipeline-step stagger-card">
          <div class="glass-enhanced glow-hover">
            <div class="glass-inner p-8 text-center">
              <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></div>
              <h3 class="font-semibold mb-2">Upload</h3>
              <p class="text-sm" style="color: var(--text-muted);">Drop an audio file in any language. MP3, WAV, M4A, or paste a link.</p>
            </div>
          </div>
        </div>
        <div class="dbx-pipeline-connector" aria-hidden="true">
          <svg viewBox="0 0 60 20" class="dbx-connector-svg">
            <line x1="0" y1="10" x2="60" y2="10" stroke="#EA8A2E" stroke-width="2" stroke-dasharray="6 4" opacity="0.4"/>
            <polygon points="52,5 60,10 52,15" fill="#EA8A2E" opacity="0.6"/>
          </svg>
        </div>
        <div class="dbx-pipeline-step stagger-card">
          <div class="glass-enhanced glow-hover">
            <div class="glass-inner p-8 text-center">
              <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg></div>
              <h3 class="font-semibold mb-2">Process</h3>
              <p class="text-sm" style="color: var(--text-muted);">AI clones the voice, translates the content, and synthesizes the output in the original speaker's voice.</p>
            </div>
          </div>
        </div>
        <div class="dbx-pipeline-connector" aria-hidden="true">
          <svg viewBox="0 0 60 20" class="dbx-connector-svg">
            <line x1="0" y1="10" x2="60" y2="10" stroke="#EA8A2E" stroke-width="2" stroke-dasharray="6 4" opacity="0.4"/>
            <polygon points="52,5 60,10 52,15" fill="#EA8A2E" opacity="0.6"/>
          </svg>
        </div>
        <div class="dbx-pipeline-step stagger-card">
          <div class="glass-enhanced glow-hover">
            <div class="glass-inner p-8 text-center">
              <div class="mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></div>
              <h3 class="font-semibold mb-2">Download</h3>
              <p class="text-sm" style="color: var(--text-muted);">Get your translated audio back in minutes. Same voice, new language. Ready to share.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- Features: Two column with waveform decorations -->
  <section class="px-6 py-20 md:py-28 accent-thread">
    <div class="max-w-4xl mx-auto fade-in reveal-right">
      <span class="section-label">Features</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-12 section-heading">Built for creators who think globally</h2>
      <div class="dbx-features-grid">
        <div class="dbx-feature-item stagger-card">
          <div class="dbx-feature-text">
            <h3 class="font-semibold mb-2">Voice Cloning Translation</h3>
            <p class="text-sm" style="color: var(--text-muted);">The translation comes out in the original speaker's voice. Not a generic TTS voice. Their actual voice, speaking your language.</p>
          </div>
          <div class="dbx-feature-viz" aria-hidden="true">
            <div class="dbx-mini-bars">
              <div class="dbx-mini-bar" style="--h: 60%; background: #1E3A5F;"></div>
              <div class="dbx-mini-bar" style="--h: 80%; background: #2a5a8a;"></div>
              <div class="dbx-mini-bar" style="--h: 45%; background: #EA8A2E;"></div>
              <div class="dbx-mini-bar" style="--h: 70%; background: #F5B041;"></div>
            </div>
          </div>
        </div>
        <div class="dbx-feature-item stagger-card">
          <div class="dbx-feature-text">
            <h3 class="font-semibold mb-2">Any Language Pair</h3>
            <p class="text-sm" style="color: var(--text-muted);">Spanish to English, Japanese to Portuguese, Arabic to French. Upload audio in any language, get it back in any other.</p>
          </div>
          <div class="dbx-feature-viz" aria-hidden="true">
            <div class="dbx-mini-bars">
              <div class="dbx-mini-bar" style="--h: 50%; background: #1E3A5F;"></div>
              <div class="dbx-mini-bar" style="--h: 65%; background: #EA8A2E;"></div>
              <div class="dbx-mini-bar" style="--h: 75%; background: #1E3A5F;"></div>
              <div class="dbx-mini-bar" style="--h: 55%; background: #F5B041;"></div>
            </div>
          </div>
        </div>
        <div class="dbx-feature-item stagger-card">
          <div class="dbx-feature-text">
            <h3 class="font-semibold mb-2">Simple Upload Flow</h3>
            <p class="text-sm" style="color: var(--text-muted);">Drop an audio file, pick your target language, get the translated audio back in minutes. No complex setup required.</p>
          </div>
          <div class="dbx-feature-viz" aria-hidden="true">
            <div class="dbx-mini-bars">
              <div class="dbx-mini-bar" style="--h: 70%; background: #EA8A2E;"></div>
              <div class="dbx-mini-bar" style="--h: 40%; background: #1E3A5F;"></div>
              <div class="dbx-mini-bar" style="--h: 85%; background: #F5B041;"></div>
              <div class="dbx-mini-bar" style="--h: 55%; background: #2a5a8a;"></div>
            </div>
          </div>
        </div>
        <div class="dbx-feature-item stagger-card">
          <div class="dbx-feature-text">
            <h3 class="font-semibold mb-2">Content Creator Ready</h3>
            <p class="text-sm" style="color: var(--text-muted);">Dub your podcasts, YouTube videos, or course content into multiple languages. Reach a global audience in your own voice.</p>
          </div>
          <div class="dbx-feature-viz" aria-hidden="true">
            <div class="dbx-mini-bars">
              <div class="dbx-mini-bar" style="--h: 45%; background: #1E3A5F;"></div>
              <div class="dbx-mini-bar" style="--h: 90%; background: #EA8A2E;"></div>
              <div class="dbx-mini-bar" style="--h: 60%; background: #2a5a8a;"></div>
              <div class="dbx-mini-bar" style="--h: 75%; background: #F5B041;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- FAQ -->
  <section class="px-6 py-20 md:py-28">
    <div class="max-w-3xl mx-auto fade-in reveal-fade">
      <span class="section-label">FAQ</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-12">Common questions</h2>
      <div class="space-y-6">
        <div class="glass-enhanced stagger-card">
          <div class="glass-inner p-6">
            <h3 class="font-semibold mb-2">How accurate is the voice cloning?</h3>
            <p class="text-sm" style="color: var(--text-muted);">Very close to the original. We use state of the art voice AI to capture tone, pitch, and speaking style. It won't be perfect, but it's remarkably close.</p>
          </div>
        </div>
        <div class="glass-enhanced stagger-card">
          <div class="glass-inner p-6">
            <h3 class="font-semibold mb-2">What audio formats are supported?</h3>
            <p class="text-sm" style="color: var(--text-muted);">MP3, WAV, M4A, OGG, and most common audio formats. Upload directly or paste a link.</p>
          </div>
        </div>
        <div class="glass-enhanced stagger-card">
          <div class="glass-inner p-6">
            <h3 class="font-semibold mb-2">Is this legal and ethical?</h3>
            <p class="text-sm" style="color: var(--text-muted);">Dubvox is designed for translating your own content or content you have permission to translate. We build with consent first architecture.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- Waitlist -->
  <section id="waitlist" class="px-6 py-20 md:py-28 waitlist-glow">
    <div class="max-w-2xl mx-auto text-center fade-in reveal-scale">
      <span class="section-label">Invite-Only Beta</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Don't miss early access</h2>
      <p class="text-base mb-10" style="color: var(--text-muted);">Spots are limited for the invite-only beta. Be among the first to translate audio in any voice.</p>
      <div class="flex flex-wrap items-center justify-center gap-3 mb-8 text-xs" style="color: var(--text-muted);">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full ring-1 ring-white/[0.08]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Early access pricing
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full ring-1 ring-white/[0.08]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
          Priority onboarding
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full ring-1 ring-white/[0.08]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Shape the product
        </span>
      </div>
      <WaitlistForm product="dubvox" />
    </div>
  </section>

  <!-- Cross links -->
  <section class="px-6 py-16">
    <div class="max-w-4xl mx-auto fade-in">
      <p class="text-center text-sm font-medium mb-6" style="color: var(--text-muted);">Also check out</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="https://dreamvoice.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">DreamVoice</a>
        <a href="https://jyko.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">Jyko</a>
        <a href="https://pryz.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">Pryz</a>
        <a href="https://sacris.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">Sacris</a>
      </div>
    </div>
  </section>
</LandingLayout>

<style>
  /* Hero */
  .dbx-hero {
    min-height: 100vh;
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  /* Split screen background */
  .dbx-split {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    pointer-events: none;
  }
  .dbx-split-left, .dbx-split-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    animation: dbx-split-in 1s cubic-bezier(0.32, 0.72, 0, 1) forwards;
  }
  .dbx-split-left {
    background: rgba(30, 58, 95, 0.08);
  }
  .dbx-split-right {
    background: rgba(234, 138, 46, 0.06);
    animation-delay: 0.3s;
  }
  @keyframes dbx-split-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .dbx-split-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }
  .dbx-split-left .dbx-split-label { color: rgba(30, 58, 95, 0.6); }
  .dbx-split-right .dbx-split-label { color: rgba(234, 138, 46, 0.6); }

  .dbx-lang-cycle {
